generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model List {
  id    Int    @id @default(autoincrement())
  name  String 
  image String
}

model GeneratedImage {
  id    Int    @id @default(autoincrement())
  name  String @unique
  url   String
}